{
  "name": "cookie-sync",
  "description": "Auto-sync YouTube cookies from Firefox to the auth service on session start. Requires `cass` CLI (brew install digibugcat/tap/cass).",
  "version": "0.1.1",
  "author": {
    "name": "digibugcat"
  },
  "license": "MIT",
  "keywords": ["hooks", "cookies", "youtube", "yt-dlp"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/sync-cookies.sh",
            "timeout": 30,
            "statusMessage": "Syncing YouTube cookies..."
          }
        ]
      }
    ]
  }
}
