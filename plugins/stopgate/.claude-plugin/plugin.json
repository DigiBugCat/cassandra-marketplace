{
  "name": "stopgate",
  "description": "Stop hook that blocks lazy stops and returns actionable directives. Uses an Opus LLM call to classify whether the assistant actually finished its task.",
  "version": "0.2.0",
  "author": {
    "name": "digibugcat"
  },
  "license": "MIT",
  "keywords": ["hooks", "stop-gate", "agentic", "productivity"],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/stopgate.sh",
            "timeout": 30,
            "statusMessage": "Checking task completion..."
          }
        ]
      }
    ]
  }
}
